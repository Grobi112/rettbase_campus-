rules_version = '2';
// RettBase Campus – angelehnt an app/firestore.rules, ohne NFS-/Fahrtenbuch-/Chat-Sonderfälle.
// Erweiterung: gleiche kunden/*-Struktur wie RettBase, damit SSD-Screens portierbar bleiben.
service cloud.firestore {
  match /databases/{database}/documents {

    function isLoggedIn() {
      return request.auth != null;
    }

    function isSuperadmin() {
      let email = request.auth.token.email;
      return email != null && (
        email == 'admin@rettbase.de' ||
        (email.matches('.*@admin.rettbase.de') && email.matches('112@.*'))
      );
    }

    function belongsToCompany(kundenId) {
      return exists(/databases/$(database)/documents/kunden/$(kundenId)/users/$(request.auth.uid));
    }

    function canAccessCompany(kundenId) {
      return isLoggedIn() && (belongsToCompany(kundenId) || isSuperadmin());
    }

    function companyUserExists(kundenId) {
      return exists(/databases/$(database)/documents/kunden/$(kundenId)/users/$(request.auth.uid));
    }

    function companyRole(kundenId) {
      return get(/databases/$(database)/documents/kunden/$(kundenId)/users/$(request.auth.uid)).data.role;
    }

    function hasCompanyRole(kundenId, allowedRoles) {
      return companyUserExists(kundenId) && companyRole(kundenId) in allowedRoles;
    }

    // Campus: Rollen für Mitarbeiterverwaltung (ohne Rettungsdienst-/NFS-Rollen).
    function canManageCompanyMembers(kundenId) {
      return isSuperadmin() || hasCompanyRole(kundenId, [
        'superadmin',
        'admin',
        'leiterssd'
      ]);
    }

    function canUpdateOwnUsersSelfServiceFields(userId) {
      return request.auth.uid == userId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'fcmToken',
          'fcmTokenUpdatedAt',
          'alarmToneId',
          'alarmNonCritical',
          'nfsAlarmVerfuegbarkeit',
          'sanitaetAlarmVerfuegbar',
          'updatedAt'
        ])
        && request.resource.data.role == resource.data.role
        && request.resource.data.companyId == resource.data.companyId;
    }

    function canUpdateOwnMitarbeiterSelfServiceFields() {
      return resource.data.uid == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'nfsAlarmVerfuegbarkeit',
          'sanitaetAlarmVerfuegbar',
          'updatedAt',
          'schichtplanVerfuegbarkeitFeedback'
        ]);
    }

    function ssdPublicAlarmOrtKannVerwalten(kundenId) {
      return isSuperadmin()
        || (exists(/databases/$(database)/documents/kunden/$(kundenId)/users/$(request.auth.uid))
            && get(/databases/$(database)/documents/kunden/$(kundenId)/users/$(request.auth.uid)).data.role in ['admin', 'leiterssd', 'superadmin']);
    }

    function ssdDienstplanKannSchreiben(kundenId) {
      return exists(/databases/$(database)/documents/kunden/$(kundenId)/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/kunden/$(kundenId)/users/$(request.auth.uid)).data.role in ['admin', 'leiterssd'];
    }

    function materialCheckSettingsKannSchreiben(kundenId) {
      return isSuperadmin()
        || (exists(/databases/$(database)/documents/kunden/$(kundenId)/users/$(request.auth.uid))
            && get(/databases/$(database)/documents/kunden/$(kundenId)/users/$(request.auth.uid)).data.role in ['admin', 'leiterssd', 'superadmin']);
    }

    match /campus_connect_selftest/{docId} {
      allow read, write: if request.auth != null && request.auth.uid == docId;
    }

    match /kunden/{kundenId} {
      allow read, write: if canAccessCompany(kundenId);

      match /mitarbeiter/{mitarbeiterId} {
        allow read: if canAccessCompany(kundenId);
        allow create, delete: if canManageCompanyMembers(kundenId);
        allow update: if canManageCompanyMembers(kundenId)
          || (canAccessCompany(kundenId) && canUpdateOwnMitarbeiterSelfServiceFields());
      }

      match /users/{userId} {
        allow read: if canAccessCompany(kundenId);
        allow create, delete: if canManageCompanyMembers(kundenId);
        allow update: if canManageCompanyMembers(kundenId)
          || (canAccessCompany(kundenId) && canUpdateOwnUsersSelfServiceFields(userId));
        match /userTiles/{docId} {
          allow read, write: if canManageCompanyMembers(kundenId) || request.auth.uid == userId;
        }
      }

      match /modules/{moduleId} {
        allow read, write: if canAccessCompany(kundenId);
      }

      match /ssdPublicAlarmOrte/{token} {
        allow read, create, update, delete: if canAccessCompany(kundenId) && ssdPublicAlarmOrtKannVerwalten(kundenId);
      }

      match /ssd_dienstplan_view_labels/{docId} {
        allow read: if canAccessCompany(kundenId);
        allow create, update, delete: if canAccessCompany(kundenId) && ssdDienstplanKannSchreiben(kundenId);
      }
      match /ssd_dienstplan_day_exceptions/{docId} {
        allow read: if canAccessCompany(kundenId);
        allow create, update, delete: if canAccessCompany(kundenId) && ssdDienstplanKannSchreiben(kundenId);
      }

      match /settings/material_check {
        allow read: if canAccessCompany(kundenId);
        allow create, update, delete: if canAccessCompany(kundenId) && materialCheckSettingsKannSchreiben(kundenId);
      }

      // z. B. settings/einsatzprotokoll-ssd — nicht material_check (eigenes match oben).
      match /settings/{docId} {
        allow read: if canAccessCompany(kundenId);
        allow create, update, delete: if canAccessCompany(kundenId) && docId != 'material_check';
      }

      match /einsatzprotokoll-ssd/{docId} {
        allow read, create, update, delete: if canAccessCompany(kundenId);
      }

      // SSD nutzt dieselbe Alarm-Collection wie in RettBase (Schreiben oft über Functions).
      match /alarmierung-nfs/{docId} {
        allow read, create, update, delete: if canAccessCompany(kundenId);
      }

      // Zähler-Collection mit Umlaut im Namen: kein Literal im Pfad (Parser), nur per Variable.
      match /{alarmSub}/{docId} {
        allow read, create, update, delete: if canAccessCompany(kundenId)
            && alarmSub == 'alarmierung-nfs-zähler';
      }
    }

    match /settings/{document=**} {
      allow read: if isLoggedIn();
      allow write: if isSuperadmin();
    }

    match /fcmTokens/{uid} {
      allow read, write: if isLoggedIn() && request.auth.uid == uid;
    }

    match /ssd_share_pins/{pin} {
      allow read, write: if false;
    }
  }
}
